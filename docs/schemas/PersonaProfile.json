{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "travel-persona://schemas/PersonaProfile.json",
  "title": "PersonaProfile",
  "description": "用户旅行人格档案 -- 长期偏好，缓慢变化。总纲3.1 Persona Core 层。不与当次取向和现实状态混合存储。",
  "type": "object",
  "required": ["profileId", "traits", "createdAt", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "profileId": {
      "type": "string",
      "description": "人格档案唯一ID"
    },
    "userId": {
      "type": "string",
      "description": "关联用户ID（账号系统上线后使用）"
    },
    "traits": {
      "type": "object",
      "description": "16维人格特征，总纲3.2定义。每维包含概率估计和置信度。",
      "required": ["restoration", "nature", "culture", "food", "pace", "social", "budget", "aesthetics", "comfort", "novelty", "transit", "lowCrowd", "authenticity", "weatherFlex", "bookingEase", "workation"],
      "additionalProperties": false,
      "patternProperties": {
        "^(restoration|nature|culture|food|pace|social|budget|aesthetics|comfort|novelty|transit|lowCrowd|authenticity|weatherFlex|bookingEase|workation)$": {
          "$ref": "#/definitions/PersonaTrait"
        }
      }
    },
    "primaryPersona": {
      "$ref": "#/definitions/PersonaTypeDisplay",
      "description": "主人格原型（派生展示，总纲3.3）。不参与推荐排序，仅用于用户理解。"
    },
    "lockedTraits": {
      "type": "array",
      "items": { "$ref": "SharedEnums.json#/definitions/TraitKey" },
      "description": "用户手动锁定的维度，自动更新不得修改"
    },
    "excludedEvidenceIds": {
      "type": "array",
      "items": { "type": "string" },
      "description": "用户明确排除的证据ID列表"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "PersonaTrait": {
      "type": "object",
      "required": ["key", "mean"],
      "additionalProperties": false,
      "properties": {
        "key": { "$ref": "SharedEnums.json#/definitions/TraitKey" },
        "mean": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "当前估计值（贝叶斯后验均值）"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5,
          "description": "证据可信度，总纲3.2 PersonaTrait.confidence"
        },
        "evidenceCount": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "累计证据数量"
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "lockedByUser": {
          "type": "boolean",
          "default": false,
          "description": "用户手动锁定，自动更新不得修改"
        }
      }
    },
    "PersonaTypeDisplay": {
      "type": "object",
      "description": "人格原型展示信息，总纲3.3。原型由当前向量与原型中心的相似度派生。",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "与原型中心的相似度"
        },
        "secondary": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "blendLabel": {
          "type": "string",
          "description": "当最高与次高差距过小时显示混合标签，如'文化慢游 × 自然恢复'"
        }
      }
    }
  }
}
