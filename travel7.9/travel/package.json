{
  "name": "travel-persona",
  "version": "0.1.0",
  "description": "旅格 Travel Persona — 基于旅游人格画像的 AI 目的地决策系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "test": "node test/verify.js",
    "sync:data": "node scripts/sync-data.js",
    "build": "node scripts/build.js",
    "validate:data": "node -e \"const di = require('./src/data/dataInterface'); console.log(JSON.stringify(di.validateAll(), null, 2));\""
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "travel",
    "ai",
    "persona",
    "recommendation",
    "claude"
  ],
  "author": "",
  "license": "MIT"
}
