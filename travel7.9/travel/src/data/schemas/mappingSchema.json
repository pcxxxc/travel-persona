{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://travel-persona.dev/schemas/mapping.json",
  "title": "维度映射表 Schema",
  "description": "旅格 Travel Persona 维度增量映射表的数据结构定义",
  "type": "object",
  "required": ["tableName", "entries"],
  "properties": {
    "tableName": {
      "type": "string",
      "description": "映射表名称",
      "enum": ["emotionGoal", "door", "duration", "budget", "nomad", "preference", "dislike", "rhythm", "risk"]
    },
    "entries": {
      "type": "object",
      "description": "键值对形式的映射条目",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "description": "单个映射条目：选项值 → 维度增量",
          "additionalProperties": false,
          "properties": {
            "freedom": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "social": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "explore": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "nature": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "pace": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
            "budget": { "type": "number", "minimum": -0.5, "maximum": 0.5 }
          }
        }
      }
    },
    "academicBasis": {
      "type": "string",
      "description": "心理学理论依据说明"
    }
  }
}